---
import SiteLayout from '../layouts/SiteLayout.astro';
import StudioApp from '../components/studio/StudioApp';

const title = 'Studio | Grabador de pantalla con camara y audio';
const description =
  'Set de grabacion streaming para capturar pantalla, camara, microfono y audio del sistema con preview real y descarga local.';
---

<SiteLayout title={title} description={description}>
  <main class="shell py-8 md:py-10">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
      <div>
        <a href="/" class="text-sm text-sky-300">Volver al sitio</a>
        <h1 class="mt-3 text-3xl font-semibold text-white md:text-4xl">Studio Recorder</h1>
        <p class="mt-2 max-w-3xl text-sm leading-7 text-slate-400">
          Set profesional para grabar tutoriales estilo streaming con camara personalizable, mezcla de audio y base lista
          para el futuro editor multipista.
        </p>
      </div>
    </div>

    <StudioApp client:only="react" />
  </main>
</SiteLayout>
